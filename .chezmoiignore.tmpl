# Files and directories that should NOT be applied by chezmoi.
# These are repo infrastructure (scripts, docs, templates, etc.)

# Repo-level files (not dotfiles)
README.md
justfile
Brewfile
.gitignore

# Scripts, docs, templates, packages (not dotfiles)
scripts/
docs/
templates/
packages/

# Per-machine files (created by post-install.sh, not in the source repo)
.gitconfig.local
.gitconfig.work
.gitconfig.personal

# Local-only state files (created at runtime, never committed to source)
.cache/
.cache/**
